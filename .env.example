# ============================================
# YouTube Blend - Production Environment
# ============================================
# Copy this file to .env and fill in your values
# This file is used by docker-compose.yml
# ============================================

# ---------- MongoDB ----------
MONGO_URI=mongodb+srv://username:password@cluster0.abc123.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# ---------- Google OAuth ----------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ---------- JWT ----------
# Generate with: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_here

# ---------- Domain Configuration ----------
# Frontend subdomain (served by Caddy)
FRONTEND_DOMAIN=youtube-blend.tanmaytiwari.me

# Backend/API subdomain (served by Caddy)
BACKEND_DOMAIN=api.youtube-blend.tanmaytiwari.me

# Full backend URL — used by backend for OAuth redirect URIs
DEPLOYED_DOMAIN=https://api.youtube-blend.tanmaytiwari.me

# Full frontend URL — used by backend for CORS allow-origin
FRONTEND_URL=https://youtube-blend.tanmaytiwari.me

# ---------- Frontend Build ----------
# Full API URL — baked into the frontend at build time
VITE_API_URL=https://api.youtube-blend.tanmaytiwari.me

# ---------- Optional ----------
ENABLE_DEBUG=false
ENABLE_FALLBACK=false
