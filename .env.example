# ============================================
# YouTube Blend - Production Environment
# ============================================
# Copy this file to .env and fill in your values
# This file is used by docker-compose.yml
# ============================================

# ---------- MongoDB ----------
MONGO_URI=mongodb+srv://username:password@cluster0.abc123.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# ---------- Google OAuth ----------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=123456789-abc123def456.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abc123def456

# ---------- JWT ----------
# Generate with: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_here

# ---------- Domain Configuration ----------
# Your Vercel domain with /api prefix (backend is proxied under /api/)
DEPLOYED_DOMAIN=https://youtube-blend.vercel.app/api

# Your Vercel domain (frontend root)
FRONTEND_URL=https://youtube-blend.vercel.app

# ---------- Frontend Build ----------
# Relative path since frontend & API share the same Vercel domain
VITE_API_URL=/api

# ---------- Optional ----------
ENABLE_DEBUG=false
ENABLE_FALLBACK=false
