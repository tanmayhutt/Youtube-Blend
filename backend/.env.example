# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster0.abc123.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=123456789-abc123def456.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abc123def456

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_secure_jwt_secret_here

# Deployment URLs
# For local development, use http://localhost:8000
DEPLOYED_DOMAIN=https://youtube-blend-backend.onrender.com

# Frontend URL (where the React app is deployed)
FRONTEND_URL=https://youtube-blend.vercel.app

# Optional: Enable fallback HTML auth endpoint
ENABLE_FALLBACK=false
